# ignore video and output files
data/
output/
runs/

# large learned weights (copy best.pt to models/ball.pt locally)
models/*.pt
models/*.onnx

# Ultralytics may download base weights into the repo root
yolov8n.pt
yolo*.pt

# Local YOLO dataset (images + labels); keep folder structure via .gitkeep
dataset/ball_yolo/images/**/*.jpg
dataset/ball_yolo/images/**/*.jpeg
dataset/ball_yolo/images/**/*.png
dataset/ball_yolo/images/**/*.webp
dataset/ball_yolo/labels/**/*.txt
dataset/ball_yolo/labels/**/*.cache

# Local agent/IDE work directories (gitlinks / worktrees)
.claude/

# ignore python junk
__pycache__/
*.pyc
.DS_Store

# Xcode / iOS (app lives under ios/)
ios/**/xcuserdata/
ios/**/*.xcuserstate
ios/**/DerivedData/
ios/DerivedData/
ios/build/
*.xcuserstate
